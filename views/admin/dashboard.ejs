<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/static/css/admin.css" />
</head>
<body class="admin-body">
  <% const active = 'dashboard'; %>
  <%- include('_chrome', { active: active, admin: admin, flash: flash }) %>

  <main class="container admin-main">
    <section class="panel">
      <header class="panel-head">
        <div>
          <h1>Dashboard</h1>
          <p class="muted">Trigger Instagram fetches and monitor ingestion.</p>
        </div>
        <div class="stat-pill">
          <span class="stat-label">Total posts</span>
          <strong><%= stats.totalPosts %></strong>
        </div>
      </header>

      <div class="panel-grid">
        <div class="panel-card">
          <h2>Fetch Instagram posts</h2>
          <p class="muted">Runs the Apify scraper and stores new posts + media.</p>
          <form method="POST" action="/admin/fetch" class="stack">
            <label class="field">
              <span>Targets (one per line, optional)</span>
              <textarea
                name="targets"
                rows="3"
                placeholder="https://www.instagram.com/instagram/"
              ><%= (defaultTargets || []).join('\n') %></textarea>
            </label>

            <div class="row">
              <label class="field">
                <span>Results limit</span>
                <input type="number" name="resultsLimit" min="1" max="200" value="20" />
              </label>
              <label class="checkbox">
                <input type="checkbox" name="includeComments" />
                <span>Include comments</span>
              </label>
              <label class="checkbox">
                <input type="checkbox" name="downloadMedia" checked />
                <span>Download media</span>
              </label>
            </div>

            <button class="btn btn-primary" type="submit">Start fetch</button>
          </form>
        </div>

        <div class="panel-card">
          <h2>Fetch via Graph API</h2>
          <p class="muted">
            Pulls from every active Graph API account stored in
            <a href="/admin/graph">Graph accounts</a>. Uses Meta's
            official API — no Apify required.
          </p>
          <% const activeGraph = (graphAccounts || []).filter(function(a){ return a.is_active; }); %>
          <% if (!(graphAccounts || []).length) { %>
            <p class="muted small">
              No Graph accounts yet.
              <a href="/admin/graph/new">Add one</a> to enable this.
            </p>
          <% } else { %>
            <ul class="recent-list small">
              <% graphAccounts.forEach(function(a) { %>
                <li>
                  <a href="/admin/graph/<%= a.id %>">
                    <strong><%= a.label %></strong>
                    <span class="muted">· <%= a.ig_business_id %></span>
                  </a>
                  <span class="muted small">
                    <%= a.is_active ? 'active' : 'paused' %>
                    <% if (a.last_fetched_at) { %> · <%= a.last_fetched_at %><% } %>
                  </span>
                </li>
              <% }) %>
            </ul>
          <% } %>
          <form method="POST" action="/admin/graph/fetch" class="stack">
            <label class="checkbox">
              <input type="checkbox" name="downloadMedia" checked />
              <span>Download media to local storage</span>
            </label>
            <button class="btn btn-primary" type="submit" <%= activeGraph.length ? '' : 'disabled' %>>
              Fetch from Graph API<% if (activeGraph.length) { %> (<%= activeGraph.length %> account<%= activeGraph.length === 1 ? '' : 's' %>)<% } %>
            </button>
          </form>
        </div>

        <div class="panel-card">
          <h2>Repair broken media</h2>
          <p class="muted">
            Redownloads posts whose image or video failed to mirror during
            ingest, and fixes reels that were stored under the wrong file
            extension so the player shows a black screen.
          </p>
          <form method="POST" action="/admin/media/redownload" class="stack">
            <label class="field">
              <span>Batch size</span>
              <input type="number" name="limit" min="1" max="500" value="100" />
            </label>
            <button class="btn btn-ghost" type="submit">Redownload &amp; fix media</button>
          </form>
        </div>

        <div class="panel-card">
          <h2>Recent posts</h2>
          <% if (!recent.length) { %>
            <p class="muted">No posts yet. Trigger a fetch to get started.</p>
          <% } else { %>
            <ul class="recent-list">
              <% recent.forEach(function(r) { %>
                <li>
                  <a href="/post/<%= r.post_id %>" target="_blank" rel="noopener">
                    <strong>@<%= r.username || 'unknown' %></strong>
                    <span class="muted"><%= r.posted_at || '' %></span>
                  </a>
                  <span class="muted small">
                    <%= r.likes_count %> likes &middot; <%= r.comments_count %> comments
                  </span>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
