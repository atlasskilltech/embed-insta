<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Embed &middot; @<%= post.username || 'post' %></title>
  <link rel="stylesheet" href="/static/css/embed.css" />
  <style>
    :root {
      --w-accent: <%= settings.accent_color %>;
      --w-bg: <%= settings.background %>;
      --w-fg: <%= settings.text_color %>;
      --w-border: <%= settings.border_color %>;
      --w-radius: <%= settings.card_radius %>px;
      --w-font: <%= settings.font_family %>;
    }
  </style>
</head>
<body class="embed-body themed">
  <article class="embed-card">
    <% if (settings.show_username) { %>
      <header class="embed-head">
        <div class="avatar"><%= (post.username || '?').slice(0, 1).toUpperCase() %></div>
        <div class="who">
          <strong>@<%= post.username || 'unknown' %></strong>
          <% if (post.owner_full_name) { %><span><%= post.owner_full_name %></span><% } %>
        </div>
      </header>
    <% } %>

    <div class="embed-media">
      <%
        const first = post.media[0];
        let altText = first && first.alt_text ? String(first.alt_text).replace(/\s+/g, ' ').trim() : '';
        if (altText.length > 80) altText = altText.slice(0, 80) + '…';
        if (!altText) altText = '@' + (post.username || 'post');
      %>
      <%
        const videoSrc = first
          ? first.local_url || (first.media_type === 'video' ? first.proxy_url : null)
          : null;
        const posterSrc = first
          ? first.local_thumbnail_url || first.proxy_thumbnail_url || ''
          : '';
        const imgSrc = first
          ? first.local_url ||
            first.local_thumbnail_url ||
            first.proxy_thumbnail_url ||
            first.proxy_url
          : null;
      %>
      <% if (first && first.media_type === 'video' && videoSrc) { %>
        <video controls playsinline preload="metadata" poster="<%= posterSrc %>">
          <source src="<%= videoSrc %>" />
        </video>
      <% } else if (imgSrc) { %>
        <img src="<%= imgSrc %>" alt="<%= altText %>" />
      <% } else { %>
        <div class="widget-placeholder widget-placeholder--gradient">
          <span><%= (post.username || '?').slice(0, 1).toUpperCase() %></span>
        </div>
      <% } %>
    </div>

    <footer class="embed-foot">
      <% if (settings.show_stats) { %>
        <div class="stats">
          <span>&hearts; <%= post.likes_count %></span>
          <span>&#128172; <%= post.comments_count %></span>
          <% if (post.video_view_count) { %><span>&#128065; <%= post.video_view_count.toLocaleString() %></span><% } %>
        </div>
      <% } %>
      <% if (settings.show_caption && post.caption) { %>
        <p class="caption"><%= post.caption %></p>
      <% } %>
      <% if (post.location) { %>
        <p class="location">&#128205; <%= post.location.name %></p>
      <% } %>
      <% if (post.permalink) { %>
        <a class="view-link" href="<%= post.permalink %>" target="_blank" rel="noopener">View on Instagram</a>
      <% } %>
    </footer>
  </article>
</body>
</html>
