<%- include('partials/header') %>

<section class="feed-header">
  <h1><%= username ? '@' + username : 'Latest Posts' %></h1>
  <p class="muted"><%= total %> post<%= total === 1 ? '' : 's' %></p>
</section>

<% if (!posts.length) { %>
  <p class="empty">No posts yet. Trigger a fetch via <code>POST /api/instagram/fetch</code>.</p>
<% } %>

<div class="grid">
  <% posts.forEach(function(post) { %>
    <%
      const cover = post.media[0];
      const coverSrc = cover
        ? cover.local_thumbnail_url || cover.local_url || cover.proxy_thumbnail_url || cover.proxy_url
        : null;
      const initial = (post.username || '?').slice(0, 1).toUpperCase();
    %>
    <a class="card" href="/post/<%= post.post_id %>">
      <div class="thumb">
        <% if (coverSrc) { %>
          <img loading="lazy" src="<%= coverSrc %>" alt="" data-fallback-initial="<%= initial %>" />
          <% if (post.post_type === 'carousel') { %><span class="badge">&#x25A3;</span><% } %>
          <% if (post.post_type === 'video') { %><span class="badge">&#9658;</span><% } %>
        <% } else { %>
          <div class="placeholder placeholder--gradient"><span><%= initial %></span></div>
        <% } %>
      </div>
      <div class="meta">
        <strong>@<%= post.username || 'unknown' %></strong>
        <span><%= post.likes_count %> likes &middot; <%= post.comments_count %> comments</span>
      </div>
    </a>
  <% }) %>
</div>

<script>
  (function () {
    document.addEventListener(
      'error',
      function (e) {
        var t = e.target;
        if (!t || t.tagName !== 'IMG' || !t.closest) return;
        var thumb = t.closest('.thumb');
        if (!thumb) return;
        var initial = (t.dataset && t.dataset.fallbackInitial) || '?';
        var ph = document.createElement('div');
        ph.className = 'placeholder placeholder--gradient';
        var span = document.createElement('span');
        span.textContent = initial;
        ph.appendChild(span);
        t.parentNode.replaceChild(ph, t);
      },
      true
    );
  })();
</script>

<% if (totalPages > 1) { %>
  <nav class="pagination">
    <% if (page > 1) { %><a href="?page=<%= page - 1 %>&pageSize=<%= pageSize %><%= username ? '&username=' + username : '' %>">&larr; Prev</a><% } %>
    <span>Page <%= page %> of <%= totalPages %></span>
    <% if (page < totalPages) { %><a href="?page=<%= page + 1 %>&pageSize=<%= pageSize %><%= username ? '&username=' + username : '' %>">Next &rarr;</a><% } %>
  </nav>
<% } %>

<%- include('partials/footer') %>
