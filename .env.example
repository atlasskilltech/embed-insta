# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=embed_insta

# Apify
APIFY_TOKEN=
APIFY_ACTOR_ID=apify/instagram-post-scraper
APIFY_RESULTS_LIMIT=20
APIFY_INCLUDE_COMMENTS=false

# Targets (comma-separated Instagram profile or post URLs)
INSTAGRAM_TARGETS=https://www.instagram.com/instagram/

# Scheduler (cron expression). Leave blank to disable.
FETCH_CRON=*/45 * * * *
# Run an Apify ingest once at server startup (in addition to the cron).
FETCH_ON_START=false

# Media storage
MEDIA_DIR=uploads/instagram

# API auth (optional). If set, write endpoints require X-API-Key header.
API_KEY=

# Admin panel session
ADMIN_SESSION_SECRET=please-change-this-to-a-long-random-string
ADMIN_SESSION_MAX_AGE_MS=28800000
ADMIN_COOKIE_SECURE=false
